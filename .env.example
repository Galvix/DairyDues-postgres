# DairyDues — runtime configuration.
# Copy to `.env` (which is gitignored) and fill in real values.
#
# flutter_dotenv loads this file at startup (see lib/main.dart).
# docker-compose also reads it for the backend services.

# Base URL of the self-hosted FastAPI backend, reachable over Tailscale.
# No trailing slash. Example:
#   API_BASE_URL=http://pi5-hostname.tailnet-name.ts.net:8000
API_BASE_URL=

# Bearer token the app sends on every request (backend API_TOKEN).
# This is the app token — NOT the PRINT_AGENT_TOKEN.
API_TOKEN=

# --- Postgres (used by docker-compose) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=dairydues

# Pre-built connection string for the API container. If the password contains
# special characters (like @), URL-encode them here (@ -> %40).
# Example: postgresql://user:p%40ss@db:5432/dairydues
DATABASE_URL=

# Separate token for the home printer agent.
PRINT_AGENT_TOKEN=
